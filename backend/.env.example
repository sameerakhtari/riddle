# The Android APK never receives this provider key.
RIDDLE_OPENAI_KEY=replace-me
RIDDLE_OPENAI_BASE=https://api.openai.com/v1
RIDDLE_OPENAI_MODEL=gpt-4o-mini
RIDDLE_OPENAI_MAX_TOKENS=700
RIDDLE_TEMPERATURE=0.7

# Shared secret between your phone and this backend.
RIDDLE_APP_TOKEN=replace-with-a-long-random-value

# Maximum accepted PNG size.
RIDDLE_MAX_PAGE_BYTES=5242880
