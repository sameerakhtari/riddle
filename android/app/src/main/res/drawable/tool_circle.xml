<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <solid android:color="#553B2617" />
            <stroke android:width="1dp" android:color="@color/diary_gold_bright" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <gradient android:angle="90" android:startColor="#2A211A15" android:endColor="#120D0907" />
            <stroke android:width="1dp" android:color="#A378532B" />
        </shape>
    </item>
</selector>
