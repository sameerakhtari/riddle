<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <solid android:color="#E4B866" />
            <stroke android:width="2dp" android:color="#F7D893" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <gradient android:angle="90" android:startColor="#D7A957" android:endColor="#9A6C31" />
            <stroke android:width="1dp" android:color="#F0CC82" />
        </shape>
    </item>
</selector>
