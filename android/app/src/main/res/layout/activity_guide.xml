<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/settings_background"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="serif"
        android:text="How to use Tom Riddle Diary"
        android:textColor="@color/diary_gold"
        android:textSize="27sp"
        android:textStyle="bold" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1"
        android:background="@drawable/settings_panel_background"
        android:padding="14dp">
        <TextView
            android:id="@+id/guideText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:lineSpacingExtra="4dp"
            android:textColor="@color/diary_text"
            android:textIsSelectable="true"
            android:textSize="15sp" />
    </ScrollView>

    <Button
        android:id="@+id/closeGuideButton"
        style="@style/RiddlePrimaryButton"
        android:layout_width="match_parent"
        android:layout_marginTop="10dp"
        android:text="Return to the diary" />
</LinearLayout>
