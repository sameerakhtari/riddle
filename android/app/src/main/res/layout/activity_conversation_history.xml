<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/diary_black"
    android:orientation="vertical"
    android:padding="18dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="serif"
        android:text="Conversations"
        android:textColor="@color/diary_gold"
        android:textSize="30sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Each entry below is a complete diary conversation, not a single message. Tap to read or continue; hold to delete."
        android:textColor="@color/diary_muted"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/newConversationButton"
            style="@style/RiddlePrimaryButton"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:text="＋ New conversation" />

        <Button
            android:id="@+id/closeHistoryButton"
            style="@style/RiddleButton"
            android:layout_width="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Close" />
    </LinearLayout>

    <TextView
        android:id="@+id/emptyHistoryText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:gravity="center"
        android:text="No conversations have been completed yet."
        android:textColor="@color/diary_muted"
        android:textSize="16sp"
        android:visibility="gone" />

    <ListView
        android:id="@+id/sessionList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1"
        android:divider="@android:color/transparent"
        android:dividerHeight="10dp"
        android:paddingBottom="12dp"
        android:scrollbars="vertical" />
</LinearLayout>
