<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/settings_background"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="serif"
        android:text="Diagnostic log"
        android:textColor="@color/diary_gold"
        android:textSize="27sp"
        android:textStyle="bold" />
    <TextView style="@style/RiddleInfoText" android:text="Old entries are automatically truncated according to the limit selected in Settings." />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1"
        android:background="@drawable/settings_panel_background"
        android:padding="10dp">
        <TextView
            android:id="@+id/logText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textColor="@color/diary_text"
            android:textIsSelectable="true"
            android:textSize="11sp" />
    </ScrollView>

    <HorizontalScrollView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:scrollbars="none">
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
            <Button android:id="@+id/refreshLogsButton" style="@style/RiddleButton" android:text="Refresh" />
            <Button android:id="@+id/exportLogsButton" style="@style/RiddleButton" android:layout_marginStart="6dp" android:text="Export" />
            <Button android:id="@+id/clearLogsButton" style="@style/RiddleButton" android:layout_marginStart="6dp" android:text="Clear" />
            <Button android:id="@+id/closeLogsButton" style="@style/RiddlePrimaryButton" android:layout_marginStart="6dp" android:text="Close" />
        </LinearLayout>
    </HorizontalScrollView>
</LinearLayout>
