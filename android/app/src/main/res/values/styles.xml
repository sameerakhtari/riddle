<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Riddle" parent="android:style/Theme.Material.Light.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowActionModeOverlay">true</item>
        <item name="android:colorAccent">@color/diary_gold</item>
        <item name="android:windowBackground">@color/diary_black</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">false</item>
    </style>

    <style name="RiddleButton" parent="android:style/Widget.Material.Button">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">44dp</item>
        <item name="android:minWidth">52dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/diary_text</item>
        <item name="android:backgroundTint">@color/diary_panel</item>
        <item name="android:paddingLeft">12dp</item>
        <item name="android:paddingRight">12dp</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="RiddlePrimaryButton" parent="RiddleButton">
        <item name="android:textColor">@color/diary_black</item>
        <item name="android:backgroundTint">@color/diary_gold</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="RiddleRoundToolButton" parent="android:style/Widget.Material.Button">
        <item name="android:layout_width">52dp</item>
        <item name="android:layout_height">52dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:background">@drawable/tool_circle</item>
        <item name="android:padding">0dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/diary_gold_bright</item>
        <item name="android:textSize">25sp</item>
    </style>

    <style name="RiddleRoundPrimaryButton" parent="RiddleRoundToolButton">
        <item name="android:background">@drawable/tool_circle_primary</item>
        <item name="android:textColor">@color/diary_black</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="RiddleSectionTitle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">24dp</item>
        <item name="android:layout_marginBottom">8dp</item>
        <item name="android:fontFamily">serif</item>
        <item name="android:textColor">@color/diary_gold_bright</item>
        <item name="android:textSize">21sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="RiddleSettingsPanel">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">10dp</item>
        <item name="android:background">@drawable/settings_panel_background</item>
        <item name="android:orientation">vertical</item>
        <item name="android:padding">15dp</item>
    </style>

    <style name="RiddlePanelTitle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:fontFamily">serif</item>
        <item name="android:textColor">@color/diary_ink</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="RiddleFieldLabel">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">12dp</item>
        <item name="android:textColor">@color/diary_ink</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="RiddleEditText" parent="android:style/Widget.Material.EditText">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:textColor">@color/diary_ink</item>
        <item name="android:textColorHint">@color/settings_muted</item>
        <item name="android:backgroundTint">@color/diary_panel</item>
        <item name="android:textSize">15sp</item>
        <item name="android:singleLine">true</item>
    </style>

    <style name="RiddleSpinner" parent="android:style/Widget.Material.Spinner.Underlined">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">50dp</item>
        <item name="android:backgroundTint">@color/diary_panel</item>
    </style>

    <style name="RiddleCheckBox" parent="android:style/Widget.Material.CompoundButton.CheckBox">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:textColor">@color/diary_ink</item>
        <item name="android:buttonTint">@color/diary_panel</item>
    </style>

    <style name="RiddleInfoText">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">6dp</item>
        <item name="android:textColor">@color/settings_muted</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="RiddleWarningText" parent="RiddleInfoText">
        <item name="android:textColor">@color/settings_warning</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>
